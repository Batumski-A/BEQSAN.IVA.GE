# Default: text files normalized to LF in repo, native checkout
* text=auto eol=lf

# Explicit: source files always LF
*.cs       text eol=lf
*.csproj   text eol=lf
*.sln      text eol=crlf
*.props    text eol=lf
*.targets  text eol=lf
*.json     text eol=lf
*.md       text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.xml      text eol=lf
*.ts       text eol=lf
*.tsx      text eol=lf
*.js       text eol=lf
*.jsx      text eol=lf
*.html     text eol=lf
*.css      text eol=lf
*.scss     text eol=lf
*.editorconfig text eol=lf

# Shell + scripts
*.sh       text eol=lf
*.ps1      text eol=crlf

# Binary
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.webp     binary
*.avif     binary
*.ico      binary
*.pdf      binary
*.zip      binary
*.gz       binary
*.db       binary
*.glb      binary
*.gltf     binary
*.woff     binary
*.woff2    binary
*.ttf      binary
*.otf      binary
