{
  "Database": {
    "ConnectionString": "Data Source=data/beqsan.db;Foreign Keys=True"
  },
  "Storage": {
    "LocalRoot": "data/uploads"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "data/logs/beqsan-worker-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14
        }
      }
    ],
    "Properties": {
      "Application": "BEQSAN.Worker"
    }
  }
}
