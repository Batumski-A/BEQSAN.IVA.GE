{
  "name": "@beqsan/root",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @beqsan/web dev",
    "dev:admin": "pnpm --filter @beqsan/admin dev",
    "build": "pnpm -r build",
    "build:web": "pnpm --filter @beqsan/web build",
    "preview": "pnpm --filter @beqsan/web preview",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "gen-api": "pnpm --filter @beqsan/api-types gen",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css,html}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css,html}\""
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "typescript": "^5.6.2"
  }
}
