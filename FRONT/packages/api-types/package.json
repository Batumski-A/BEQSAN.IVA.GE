{
  "name": "@beqsan/api-types",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./generated": "./generated/v1.d.ts"
  },
  "scripts": {
    "gen": "openapi-typescript http://localhost:5000/openapi/v1.json -o ./generated/v1.d.ts",
    "gen:check": "openapi-typescript http://localhost:5000/openapi/v1.json -o ./generated/v1.check.d.ts && diff -q ./generated/v1.d.ts ./generated/v1.check.d.ts && rm ./generated/v1.check.d.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "openapi-typescript": "^7.4.2",
    "typescript": "^5.6.2"
  }
}
